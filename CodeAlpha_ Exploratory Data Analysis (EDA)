        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def perform_eda(csv_path):\n",
        "    \"\"\"Performs a comprehensive EDA on a given CSV dataset.\"\"\"\n",
        "    print(f\"--- Loading Data: {csv_path} ---\")\n",
        "    try:\n",
        "        df = pd.read_csv(csv_path)\n",
        "    except FileNotFoundError:\n",
        "        print(\"Error: Dataset not found. Please provide a valid CSV path.\")\n",
        "        return\n",
        "\n",
        "    # 1. Basic Structure and Data Types [cite: 31]\n",
        "    print(\"\\n--- Data Info ---\")\n",
        "    df.info()\n",
        "\n",
        "    # 2. Statistical Summary\n",
        "    print(\"\\n--- Statistical Summary ---\")\n",
        "    print(df.describe(include='all'))\n",
        "\n",
        "    # 3. Detect Missing Values [cite: 33]\n",
        "    print(\"\\n--- Missing Values ---\")\n",
        "    missing_data = df.isnull().sum()\n",
        "    print(missing_data[missing_data > 0])\n",
        "\n",
        "    # 4. Handle Missing Data (Example: Forward fill or drop)\n",
        "    df_cleaned = df.dropna()\n",
        "\n",
        "    # 5. Correlation Heatmap (Identifying patterns/trends) [cite: 32]\n",
        "    # Select only numeric columns for correlation\n",
        "    numeric_df = df_cleaned.select_dtypes(include=['float64', 'int64'])\n",
        "\n",
        "    if not numeric_df.empty:\n",
        "        plt.figure(figsize=(10, 6))\n",
        "        sns.heatmap(numeric_df.corr(), annot=True, cmap='coolwarm', fmt=\".2f\")\n",
        "        plt.title('Feature Correlation Heatmap')\n",
        "        plt.tight_layout()\n",
        "        plt.show()\n",
        "    else:\n",
        "        print(\"\\nNo numeric columns available for correlation heatmap.\")\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    # Replace with your actual dataset path\n",
        "    # Example uses a built-in seaborn dataset for demonstration\n",
        "    sample_df = sns.load_dataset(\"titanic\")\n",
        "    sample_df.to_csv(\"sample_data.csv\", index=False)\n",
        "\n",
        "    perform_eda(\"sample_data.csv\")"
      ]
